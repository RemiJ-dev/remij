{% set pageTitle = page.title %}

{% extends 'base.html.twig' %}

{% block meta_title page.title ~ ' - ' ~ parent() %}

{% block content %}

    {{ page.content|raw }}

    {{ form_start(form) }}
        {{ form_errors(form) }}
        {{ form_row(form.name, { label: 'contact.form.name', attr: { autocomplete: 'name' } }) }}
        {{ form_row(form.email, { label: 'contact.form.email', attr: { autocomplete: 'email' } }) }}
        {{ form_row(form.subject, { label: 'contact.form.subject' }) }}
        {{ form_row(form.message, { label: 'contact.form.message', attr: { rows: 6 } }) }}
        {{ form_row(form.captcha, { label: 'contact.form.captcha' }) }}
        <button type="submit" class="btn btn-primary">{{ 'contact.form.submit'|trans }}</button>
    {{ form_end(form) }}

{% endblock %}

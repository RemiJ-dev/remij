{% set page = content_get('App\\Domain\\Page\\Model\\Page', 'home') %}

{% set pageTitle = page.title %}

{% extends 'base.html.twig' %}

{% block meta_title page.title %}

{% block meta %}
    {{ parent() }}
{% endblock %}

{% block content %}

    {{ page.content|raw }}

    {% for section in sections %}
        {{ include('pages/sections/' ~ section.type.value ~ '.html.twig', {
            section: section,
            page: page,
        }, with_context=false) }}
    {% endfor %}

{% endblock %}
